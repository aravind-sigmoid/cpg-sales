# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cpg_sales
POSTGRES_USER=cpg_user
POSTGRES_PASSWORD=cpg_password

# OpenAI — replace with your actual key
OPENAI_API_KEY=sk-dummy-replace-with-your-actual-openai-key
OPENAI_MODEL=gpt-4o-mini

# API
API_HOST=0.0.0.0
API_PORT=8000

# UI
API_BASE_URL=http://localhost:8000
